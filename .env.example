# --- PostgreSQL (either full URL or discrete fields) ---
DATABASE_URL=
# If DATABASE_URL is empty, these are used:
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=app

# Schema + dynamic table (identifiers: letters, digits, underscore only)
DB_SCHEMA=public
PROJECTS_TABLE=projects
PROJECTS_ID_COLUMN=id
# Comma-separated columns merged into the payload sent to the LLM
PROJECTS_PAYLOAD_COLUMNS=name,description,metadata

# --- Scheduler (one of: set CRON, or interval seconds) ---
VALIDATION_CRON=
VALIDATION_INTERVAL_SECONDS=3600

# --- Chunks ---
VALIDATION_CHUNK_SIZE=20

# --- LLM (OpenAI-compatible) ---
LLM_BASE_URL=https://api.openai.com
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_CHAT_COMPLETIONS_PATH=/v1/chat/completions
LLM_REQUEST_TIMEOUT_SECONDS=120
LLM_STRICT_JSON_SCHEMA=true

# --- Reports & YAML config ---
REPORTS_DIR=
PUBLIC_PROMPT_FILE=
PUBLIC_RULES_FILE=

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
# If set, required header X-Admin-Key for sensitive routes
ADMIN_API_KEY=
